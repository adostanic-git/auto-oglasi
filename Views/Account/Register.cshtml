@model AutoOglasi.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Registracija";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">Registracija</h3>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ImeIPrezime" class="form-label">Ime i prezime</label>
                        <input asp-for="ImeIPrezime" class="form-control" placeholder="Ime Prezime" />
                        <span asp-validation-for="ImeIPrezime" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="email@primer.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Lozinka" class="form-label">Lozinka</label>
                        <input asp-for="Lozinka" class="form-control" placeholder="Minimum 6 karaktera" />
                        <span asp-validation-for="Lozinka" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PotvrdaLozinke" class="form-label">Potvrda lozinke</label>
                        <input asp-for="PotvrdaLozinke" class="form-control" placeholder="Ponovite lozinku" />
                        <span asp-validation-for="PotvrdaLozinke" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100">Registruj se</button>
                </form>

                <hr />
                <p class="text-center mb-0">
                    Već imate nalog? <a asp-action="Login">Prijavite se</a>
                </p>
            </div>
        </div>
    </div>
</div>