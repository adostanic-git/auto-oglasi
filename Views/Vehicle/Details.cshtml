@model AutoOglasi.Models.Vehicle

@{
    ViewData["Title"] = $"{Model.Marka} {Model.Model}";
}

<div class="row">
    <div class="col-md-8">
        <h2>@Model.Marka @Model.Model (@Model.Godiste)</h2>
        <h4 class="text-success">@Model.Cena.ToString("N0") €</h4>
        <p class="mt-3">@Model.Opis</p>

        @if (Model.Slike.Any())
        {
            <div class="row mt-3">
                @foreach (var slika in Model.Slike)
                {
                    <div class="col-md-4 mb-3">
                        <img src="@slika" class="img-fluid rounded shadow-sm" alt="Slika vozila" />
                    </div>
                }
            </div>
        }

        <div class="mt-4">
            <a asp-action="Index" class="btn btn-secondary">← Nazad na listu</a>

            @if (ViewBag.IsOwner == true)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning ms-2">Izmeni</a>

                <form asp-action="Delete" asp-route-id="@Model.Id"
                      method="post" class="d-inline ms-2"
                      onsubmit="return confirm('Jeste li sigurni da želite obrisati oglas?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Ukloni</button>
                </form>
            }
        </div>
    </div>
</div>