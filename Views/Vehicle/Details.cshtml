@model AutoOglasi.Models.Vehicle
@{
    ViewData["Title"] = $"{Model.Marka} {Model.Model}";
    bool isOwner = (bool)(ViewBag.IsOwner ?? false);
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none text-muted small">← Nazad na listu</a>
</div>

<div class="row g-4">
    <div class="col-md-7">
        @if (Model.Slike.Any())
        {
            <div id="vehicleCarousel" class="carousel slide shadow-sm rounded" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Slike.Count; i++)
                    {
                        <button type="button" data-bs-target="#vehicleCarousel" data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
                    }
                </div>
                <div class="carousel-inner rounded">
                    @for (int i = 0; i < Model.Slike.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="@Model.Slike[i]" class="d-block w-100 carousel-img" alt="Slika @(i + 1)" />
                        </div>
                    }
                </div>
                @if (Model.Slike.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#vehicleCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#vehicleCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="no-image-lg d-flex align-items-center justify-content-center rounded shadow-sm">
                <span class="text-muted fs-5">Nema slika</span>
            </div>
        }
    </div>

    <div class="col-md-5">
        <h2 class="fw-bold">@Model.Marka @Model.Model</h2>

        <div class="mb-3">
            <span class="badge bg-secondary me-2">@Model.Godiste. god.</span>
        </div>

        <p class="fs-3 fw-bold text-primary mb-4">@Model.Cena.ToString("N0") €</p>

        <div class="mb-4">
            <h6 class="fw-bold text-muted text-uppercase small mb-2">Opis</h6>
            <p class="lh-lg">@Model.Opis</p>
        </div>

        @if (isOwner)
        {
            <div class="d-flex gap-2 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary flex-grow-1">
                    Izmeni oglas
                </a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Da li ste sigurni da želite da obrišete ovaj oglas?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger">Obriši</button>
                </form>
            </div>
        }
    </div>
</div>
