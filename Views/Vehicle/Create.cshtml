@model AutoOglasi.Models.VehicleCreateViewModel
@{
    ViewData["Title"] = "Postavi oglas";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center mb-4 gap-3">
            <a asp-action="Index" class="text-decoration-none text-muted small">← Nazad</a>
            <h2 class="fw-bold mb-0">Postavi oglas</h2>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Marka" class="form-label fw-semibold"></label>
                            <input asp-for="Marka" class="form-control" placeholder="npr. Volkswagen" />
                            <span asp-validation-for="Marka" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label fw-semibold"></label>
                            <input asp-for="Model" class="form-control" placeholder="npr. Golf 7" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Godiste" class="form-label fw-semibold"></label>
                            <input asp-for="Godiste" class="form-control" type="number" min="1900" max="2026" placeholder="npr. 2019" />
                            <span asp-validation-for="Godiste" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Cena" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Cena" class="form-control" type="number" min="0" step="100" placeholder="npr. 12500" />
                                <span class="input-group-text">€</span>
                            </div>
                            <span asp-validation-for="Cena" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Opis" class="form-label fw-semibold"></label>
                        <textarea asp-for="Opis" class="form-control" rows="4"
                                  placeholder="Opišite vozilo — stanje, oprema, razlog prodaje..."></textarea>
                        <span asp-validation-for="Opis" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Slike</label>
                        <input type="file" name="Slike" class="form-control" multiple accept="image/*" id="slikeInput" />
                        <div class="form-text">Možete odabrati više slika (JPG, PNG, WEBP).</div>
                        <div id="imagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1 fw-semibold">Postavi oglas</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('slikeInput').addEventListener('change', function () {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            for (const file of this.files) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'preview-thumb rounded';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
