@model AutoOglasi.Models.VehicleCreateViewModel

@{
    ViewData["Title"] = "Postavi oglas";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Postavi oglas</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Marka" class="form-label"></label>
                <input asp-for="Marka" class="form-control" />
                <span asp-validation-for="Marka" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Model" class="form-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Godiste" class="form-label"></label>
                <input asp-for="Godiste" class="form-control" type="number" />
                <span asp-validation-for="Godiste" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Cena" class="form-label"></label>
                <input asp-for="Cena" class="form-control" type="number" />
                <span asp-validation-for="Cena" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Opis" class="form-label"></label>
                <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slike" class="form-label"></label>
                <input asp-for="Slike" class="form-control" type="file" multiple accept="image/*" />
            </div>

            <button type="submit" class="btn btn-success w-100">Postavi oglas</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary w-100 mt-2">Odustani</a>
        </form>
    </div>
</div>