@model AutoOglasi.Models.VehicleEditViewModel

@{
    ViewData["Title"] = "Izmeni oglas";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Izmeni oglas</h2>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Cena" class="form-label"></label>
                <input asp-for="Cena" class="form-control" type="number" />
                <span asp-validation-for="Cena" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Opis" class="form-label"></label>
                <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            @if (Model.PostojeceSlike.Any())
            {
                <div class="mb-3">
                    <label class="form-label">Postojeće slike (označi za brisanje)</label>
                    <div class="row">
                        @for (int i = 0; i < Model.PostojeceSlike.Count; i++)
                        {
                            <div class="col-md-4 mb-2 text-center">
                                <img src="@Model.PostojeceSlike[i]" class="img-fluid rounded mb-1"
                                     style="height:100px; object-fit:cover;" />
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input"
                                           name="SlikeZaBrisanje" value="@Model.PostojeceSlike[i]" />
                                    <label class="form-check-label text-danger">Obriši</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="NoveSlike" class="form-label"></label>
                <input asp-for="NoveSlike" class="form-control" type="file"
                       multiple accept="image/*" />
            </div>

            <button type="submit" class="btn btn-warning w-100">Sačuvaj izmene</button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Odustani</a>
        </form>
    </div>
</div>