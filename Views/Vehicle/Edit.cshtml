@model AutoOglasi.Models.VehicleEditViewModel
@{
    ViewData["Title"] = "Izmeni oglas";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center mb-4 gap-3">
            <a asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-muted small">← Nazad</a>
            <h2 class="fw-bold mb-0">Izmeni oglas</h2>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Cena" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Cena" class="form-control" type="number" min="0" step="100" />
                            <span class="input-group-text">€</span>
                        </div>
                        <span asp-validation-for="Cena" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Opis" class="form-label fw-semibold"></label>
                        <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Opis" class="text-danger small"></span>
                    </div>

                    @if (Model.PostojeceSlike.Any())
                    {
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Postojeće slike</label>
                            <p class="form-text mb-2">Označite slike koje želite da uklonite.</p>
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var slika in Model.PostojeceSlike)
                                {
                                    <div class="existing-image-wrapper">
                                        <img src="@slika" class="existing-thumb rounded" alt="Slika vozila" />
                                        <div class="form-check mt-1 text-center">
                                            <input class="form-check-input" type="checkbox"
                                                   name="SlikeZaBrisanje" value="@slika" id="del_@slika.GetHashCode()" />
                                            <label class="form-check-label text-danger small" for="del_@slika.GetHashCode()">
                                                Ukloni
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Dodaj nove slike</label>
                        <input type="file" name="NoveSlike" class="form-control" multiple accept="image/*" id="noveSlikeInput" />
                        <div class="form-text">Dodajte nove slike uz postojeće.</div>
                        <div id="newImagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1 fw-semibold">Sačuvaj izmene</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('noveSlikeInput').addEventListener('change', function () {
            const preview = document.getElementById('newImagePreview');
            preview.innerHTML = '';
            for (const file of this.files) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'preview-thumb rounded';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
